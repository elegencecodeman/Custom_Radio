# Copy to server/.env and fill in real values. Do not commit server/.env.
PORT=8080
HOST=127.0.0.1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

GO_MUSIC_API_BASE_URL=http://127.0.0.1:8081
GO_MUSIC_SOURCE=kugou
GO_MUSIC_SOURCES=netease,qq,kugou,kuwo,migu
FISH_AUDIO_API_KEY=your_fish_audio_api_key
FISH_AUDIO_BASE_URL=https://api.fish.audio
FISH_AUDIO_MODEL=s2-pro
FISH_AUDIO_REFERENCE_ID=
FISH_AUDIO_SAMPLE_RATE=44100
FISH_AUDIO_MP3_BITRATE=128
FISH_AUDIO_PROXY=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
OPENWEATHER_API_KEY=your_openweather_api_key
UPNP_RENDERER_URL=
